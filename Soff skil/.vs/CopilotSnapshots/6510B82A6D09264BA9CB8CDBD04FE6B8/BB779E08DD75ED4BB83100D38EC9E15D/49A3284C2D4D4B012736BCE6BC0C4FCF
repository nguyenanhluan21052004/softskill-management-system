using Microsoft.EntityFrameworkCore;
using Soff_skil.Data;
using Soff_skil.DTOs;
using Soff_skil.Models;

namespace Soff_skil.Services;

public class SoftSkillService : ISoftSkillService
{
    private readonly ApplicationDbContext _dbContext;

    public SoftSkillService(ApplicationDbContext dbContext)
    {
        _dbContext = dbContext;
    }

    public async Task<IReadOnlyList<SoftSkillResultDto>> GetResultsAsync(CancellationToken cancellationToken = default)
    {
        var evaluations = await _dbContext.Evaluations
            .AsNoTracking()
            .Include(x => x.Details)
            .Include(x => x.Student)
            .GroupBy(x => x.StudentId)
            .Select(group => group
                .OrderByDescending(x => x.WeekNumber)
                .ThenByDescending(x => x.EvaluationDate)
                .FirstOrDefault())
            .ToListAsync(cancellationToken);

        return evaluations
            .Where(x => x != null)
            .Select(x => MapToResultDto(x!))
            .OrderBy(x => x.StudentName)
            .ToList();
    }

    public async Task<IReadOnlyList<SoftSkillResultDto>> GetTopResultsAsync(int limit, CancellationToken cancellationToken = default)
    {
        var normalizedLimit = limit <= 0 ? 5 : limit;
        var results = await GetResultsAsync(cancellationToken);

        return results
            .OrderByDescending(x => x.Score)
            .Take(normalizedLimit)
            .ToList();
    }

    public async Task<SoftSkillStatisticsDto> GetStatisticsAsync(CancellationToken cancellationToken = default)
    {
        var results = await GetResultsAsync(cancellationToken);

        if (results.Count == 0)
        {
            return new SoftSkillStatisticsDto();
        }

        return new SoftSkillStatisticsDto
        {
            TotalStudents = results.Count,
            AverageScore = Math.Round(results.Average(x => x.Score), 2),
            Good = results.Count(x => x.Level == SoftSkillCalculator.LevelGood),
            Average = results.Count(x => x.Level == SoftSkillCalculator.LevelAverage),
            Weak = results.Count(x => x.Level == SoftSkillCalculator.LevelWeak)
        };
    }

    public async Task<EvaluationCreateResponseDto> CreateEvaluationAsync(
        EvaluationCreateRequestDto request,
        CancellationToken cancellationToken = default)
    {
        var studentExists = await _dbContext.Students
            .AnyAsync(x => x.Id == request.StudentId, cancellationToken);

        if (!studentExists)
        {
            throw new InvalidOperationException($"Student {request.StudentId} was not found.");
        }

        var evaluationDate = request.EvaluationDate == default ? DateTime.UtcNow : request.EvaluationDate;
        var communication = SoftSkillCalculator.CalculateCommunication(
            request.Presentation,
            request.Assignment,
            request.PeerReview);
        var teamwork = SoftSkillCalculator.CalculateTeamwork(
            request.PeerReview,
            request.TeamContribution,
            request.Project);
        var criticalThinking = SoftSkillCalculator.CalculateCriticalThinking(request.Assignment, request.Project);
        var timeManagement = SoftSkillCalculator.CalculateTimeManagement(request.Attendance, request.Assignment);
        var finalScore = SoftSkillCalculator.CalculateFinalScore(
            communication,
            teamwork,
            criticalThinking,
            timeManagement);

        var evaluation = new Evaluation
        {
            StudentId = request.StudentId,
            EvaluatorId = request.EvaluatorId,
            EvaluatorType = request.EvaluatorType,
            WeekNumber = request.WeekNumber,
            EvaluationDate = evaluationDate,
            Comment = request.TeacherComment ?? string.Empty,
            Details = new List<EvaluationDetail>
            {
                new()
                {
                    SkillType = "Communication",
                    Score = communication,
                    Weight = SoftSkillCalculator.CommunicationWeight,
                    Comment = string.Empty
                },
                new()
                {
                    SkillType = "Teamwork",
                    Score = teamwork,
                    Weight = SoftSkillCalculator.TeamworkWeight,
                    Comment = string.Empty
                },
                new()
                {
                    SkillType = "CriticalThinking",
                    Score = criticalThinking,
                    Weight = SoftSkillCalculator.CriticalThinkingWeight,
                    Comment = string.Empty
                },
                new()
                {
                    SkillType = "TimeManagement",
                    Score = timeManagement,
                    Weight = SoftSkillCalculator.TimeManagementWeight,
                    Comment = string.Empty
                }
            }
        };

        await UpsertStudentActivityAsync(request, cancellationToken);
        _dbContext.Evaluations.Add(evaluation);
        await _dbContext.SaveChangesAsync(cancellationToken);

        await UpsertProgressTrackingAsync(request.StudentId, request.WeekNumber, finalScore, cancellationToken);
        var recommendations = await CreateRecommendationsAsync(
            request.StudentId,
            communication,
            teamwork,
            cancellationToken);

        return new EvaluationCreateResponseDto
        {
            EvaluationId = evaluation.EvaluationId,
            StudentId = evaluation.StudentId,
            EvaluatorId = evaluation.EvaluatorId,
            EvaluatorType = evaluation.EvaluatorType,
            WeekNumber = evaluation.WeekNumber,
            EvaluationDate = evaluation.EvaluationDate,
            TeacherComment = evaluation.Comment,
            Attendance = SoftSkillCalculator.NormalizeSkill(request.Attendance),
            Assignment = SoftSkillCalculator.NormalizeSkill(request.Assignment),
            Presentation = SoftSkillCalculator.NormalizeSkill(request.Presentation),
            Project = SoftSkillCalculator.NormalizeSkill(request.Project),
            PeerReview = SoftSkillCalculator.NormalizeSkill(request.PeerReview),
            TeamContribution = SoftSkillCalculator.NormalizeSkill(request.TeamContribution),
            Communication = communication,
            Teamwork = teamwork,
            CriticalThinking = criticalThinking,
            TimeManagement = timeManagement,
            FinalScore = finalScore,
            Level = SoftSkillCalculator.ClassifyLevel(finalScore),
            Recommendations = recommendations
        };
    }

    public async Task<IReadOnlyList<CreateEvaluationDto>> GetEvaluationsByStudentAsync(int studentId, CancellationToken cancellationToken = default)
    {
        var evaluations = await _dbContext.Evaluations
            .AsNoTracking()
            .Include(x => x.Details)
            .Where(x => x.StudentId == studentId)
            .OrderByDescending(x => x.WeekNumber)
            .ThenByDescending(x => x.EvaluationDate)
            .ToListAsync(cancellationToken);

        return evaluations.Select(MapToCreateDto).ToList();
    }

    public async Task<StudentProgressDto?> GetStudentProgressAsync(int studentId, CancellationToken cancellationToken = default)
    {
        var student = await _dbContext.Students
            .AsNoTracking()
            .SingleOrDefaultAsync(x => x.Id == studentId, cancellationToken);

        if (student == null)
        {
            return null;
        }

        var progress = await _dbContext.ProgressTrackings
            .AsNoTracking()
            .Where(x => x.StudentId == studentId)
            .OrderBy(x => x.WeekNumber)
            .ToListAsync(cancellationToken);

        var weeklyTrackings = progress.Select(MapToWeeklyTrackingDto).ToList();
        var latest = progress.OrderByDescending(x => x.WeekNumber).FirstOrDefault();
        var latestScore = latest?.TotalScore ?? 0;

        return new StudentProgressDto
        {
            StudentId = student.Id,
            StudentName = student.Name,
            CurrentScore = SoftSkillCalculator.NormalizeDashboardScore(latestScore),
            Level = SoftSkillCalculator.ClassifyLevel(latestScore),
            AlertFlag = latest?.AlertFlag ?? false,
            LatestWeek = latest?.WeekNumber ?? 0,
            WeeklyTrackings = weeklyTrackings
        };
    }

    public async Task<IReadOnlyList<RecommendationDto>> GetRecommendationsAsync(int studentId, CancellationToken cancellationToken = default)
    {
        var recommendations = await _dbContext.Recommendations
            .AsNoTracking()
            .Where(x => x.StudentId == studentId)
            .OrderByDescending(x => x.CreatedAt)
            .ToListAsync(cancellationToken);

        return recommendations
            .Select(recommendation => new RecommendationDto
            {
                RecommendationId = recommendation.RecommendationId,
                StudentId = recommendation.StudentId,
                SkillType = recommendation.SkillType,
                Suggestion = recommendation.Suggestion,
                CreatedAt = recommendation.CreatedAt
            })
            .ToList();
    }

    public async Task<IReadOnlyList<StudentProgressDto>> GetTopStudentsAsync(int limit, CancellationToken cancellationToken = default)
    {
        var normalizedLimit = limit <= 0 ? 5 : limit;
        var latestProgress = await GetLatestProgressEntriesAsync(cancellationToken);

        return latestProgress
            .OrderByDescending(x => x.Progress.TotalScore)
            .Take(normalizedLimit)
            .Select(x => MapToStudentProgressDto(x.Student, x.Progress))
            .ToList();
    }

    public async Task<IReadOnlyList<StudentProgressDto>> GetAtRiskStudentsAsync(int limit, CancellationToken cancellationToken = default)
    {
        var normalizedLimit = limit <= 0 ? 5 : limit;
        var latestProgress = await GetLatestProgressEntriesAsync(cancellationToken);

        return latestProgress
            .Where(x => x.Progress.AlertFlag || x.Progress.TotalScore < SoftSkillCalculator.AlertThreshold)
            .OrderBy(x => x.Progress.TotalScore)
            .Take(normalizedLimit)
            .Select(x => MapToStudentProgressDto(x.Student, x.Progress))
            .ToList();
    }

    private async Task UpsertProgressTrackingAsync(int studentId, int weekNumber, double totalScore, CancellationToken cancellationToken)
    {
        var progress = await _dbContext.ProgressTrackings
            .SingleOrDefaultAsync(x => x.StudentId == studentId && x.WeekNumber == weekNumber, cancellationToken);

        if (progress == null)
        {
            progress = new ProgressTracking
            {
                StudentId = studentId,
                WeekNumber = weekNumber
            };
            _dbContext.ProgressTrackings.Add(progress);
        }

        progress.TotalScore = totalScore;
        progress.AlertFlag = totalScore < SoftSkillCalculator.AlertThreshold;
        progress.UpdatedAt = DateTime.UtcNow;

        await _dbContext.SaveChangesAsync(cancellationToken);
        await UpdateRankingsAsync(weekNumber, cancellationToken);
    }

    private async Task UpdateRankingsAsync(int weekNumber, CancellationToken cancellationToken)
    {
        var progressEntries = await _dbContext.ProgressTrackings
            .Where(x => x.WeekNumber == weekNumber)
            .OrderByDescending(x => x.TotalScore)
            .ToListAsync(cancellationToken);

        var rank = 1;
        foreach (var entry in progressEntries)
        {
            entry.Rank = rank++;
            entry.AlertFlag = entry.TotalScore < SoftSkillCalculator.AlertThreshold;
            entry.UpdatedAt = DateTime.UtcNow;
        }

        await _dbContext.SaveChangesAsync(cancellationToken);
    }

    private async Task CreateRecommendationsAsync(int studentId, IEnumerable<EvaluationDetail> details, CancellationToken cancellationToken)
    {
        var recommendations = details
            .Where(detail => SoftSkillCalculator.NormalizeSkill(detail.Score) < SoftSkillCalculator.AlertThreshold)
            .Select(detail => new Recommendation
            {
                StudentId = studentId,
                SkillType = detail.SkillType,
                Suggestion = SoftSkillCalculator.BuildSuggestion(detail.SkillType),
                CreatedAt = DateTime.UtcNow
            })
            .ToList();

        if (recommendations.Count == 0)
        {
            return;
        }

        _dbContext.Recommendations.AddRange(recommendations);
        await _dbContext.SaveChangesAsync(cancellationToken);
    }

    private async Task<IReadOnlyList<(Student Student, ProgressTracking Progress)>> GetLatestProgressEntriesAsync(CancellationToken cancellationToken)
    {
        var latestProgress = await _dbContext.ProgressTrackings
            .AsNoTracking()
            .GroupBy(x => x.StudentId)
            .Select(group => group
                .OrderByDescending(x => x.WeekNumber)
                .ThenByDescending(x => x.UpdatedAt)
                .FirstOrDefault())
            .Where(x => x != null)
            .ToListAsync(cancellationToken);

        var studentIds = latestProgress.Select(x => x!.StudentId).ToList();
        var students = await _dbContext.Students
            .AsNoTracking()
            .Where(x => studentIds.Contains(x.Id))
            .ToDictionaryAsync(x => x.Id, cancellationToken);

        return latestProgress
            .Select(progress => (students[progress!.StudentId], progress!))
            .ToList();
    }

    private static SoftSkillResultDto MapToResultDto(Evaluation evaluation)
    {
        var communication = GetSkillScore(evaluation.Details, "Communication");
        var teamwork = GetSkillScore(evaluation.Details, "Teamwork");
        var criticalThinking = GetSkillScore(evaluation.Details, "CriticalThinking");
        var timeManagement = GetSkillScore(evaluation.Details, "TimeManagement");

        var score = SoftSkillCalculator.CalculateFinalScore(
            communication,
            teamwork,
            criticalThinking,
            timeManagement);
        var normalizedScore = SoftSkillCalculator.NormalizeDashboardScore(score);

        return new SoftSkillResultDto
        {
            Id = string.IsNullOrWhiteSpace(evaluation.Student?.ClassCode)
                ? $"SV{evaluation.StudentId:000}"
                : evaluation.Student.ClassCode,
            StudentName = evaluation.Student?.Name ?? string.Empty,
            Score = normalizedScore,
            Level = SoftSkillCalculator.ClassifyLevel(score),
            Skills = new SoftSkillBreakdownDto
            {
                Communication = communication,
                Teamwork = teamwork,
                CriticalThinking = criticalThinking,
                TimeManagement = timeManagement
            },
            ParticipationRate = 0,
            ContributionRate = 0,
            OnTimeRate = 0
        };
    }

    private static double GetSkillScore(IEnumerable<EvaluationDetail> details, string skillType)
    {
        var normalizedType = NormalizeSkillType(skillType);
        var detail = details.FirstOrDefault(x => NormalizeSkillType(x.SkillType) == normalizedType);
        return detail == null ? 0 : SoftSkillCalculator.NormalizeSkill(detail.Score);
    }

    private static string NormalizeSkillType(string skillType)
    {
        return string.Concat(skillType
            .Where(ch => ch != '_' && ch != ' '))
            .ToLowerInvariant();
    }

    private static CreateEvaluationDto MapToCreateDto(Evaluation evaluation)
    {
        return new CreateEvaluationDto
        {
            EvaluationId = evaluation.EvaluationId,
            StudentId = evaluation.StudentId,
            EvaluatorId = evaluation.EvaluatorId,
            EvaluatorType = evaluation.EvaluatorType,
            WeekNumber = evaluation.WeekNumber,
            EvaluationDate = evaluation.EvaluationDate,
            Comment = evaluation.Comment,
            Details = evaluation.Details.Select(detail => new EvaluationDetailDto
            {
                SkillType = detail.SkillType,
                Score = detail.Score,
                Weight = detail.Weight,
                Comment = detail.Comment
            }).ToList()
        };
    }

    private static WeeklyTrackingDto MapToWeeklyTrackingDto(ProgressTracking tracking)
    {
        return new WeeklyTrackingDto
        {
            WeekNumber = tracking.WeekNumber,
            TotalScore = SoftSkillCalculator.NormalizeDashboardScore(tracking.TotalScore),
            Rank = tracking.Rank,
            AlertFlag = tracking.AlertFlag,
            UpdatedAt = tracking.UpdatedAt
        };
    }

    private static StudentProgressDto MapToStudentProgressDto(Student student, ProgressTracking tracking)
    {
        var normalizedScore = SoftSkillCalculator.NormalizeDashboardScore(tracking.TotalScore);

        return new StudentProgressDto
        {
            StudentId = student.Id,
            StudentName = student.Name,
            CurrentScore = normalizedScore,
            Level = SoftSkillCalculator.ClassifyLevel(tracking.TotalScore),
            AlertFlag = tracking.AlertFlag,
            LatestWeek = tracking.WeekNumber,
            WeeklyTrackings = new List<WeeklyTrackingDto> { MapToWeeklyTrackingDto(tracking) }
        };
    }
}
