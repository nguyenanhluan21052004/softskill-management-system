using Soff_skil.DTOs;
using Soff_skil.Services;

namespace Soff_skil.Tests;

public class SoftSkillCalculatorTests
{
    [Fact]
    public void CalculateScore_ShouldFollowWeightedFormula()
    {
        var score = SoftSkillCalculator.CalculateWeightedScore(new List<EvaluationDetailDto>
        {
            new() { SkillType = "Communication", Score = 8.4, Weight = 0.25 },
            new() { SkillType = "Teamwork", Score = 8.8, Weight = 0.30 },
            new() { SkillType = "CriticalThinking", Score = 8.2, Weight = 0.25 },
            new() { SkillType = "TimeManagement", Score = 8.1, Weight = 0.20 }
        });

        Assert.Equal(8.41, Math.Round(score, 2));
    }

    [Theory]
    [InlineData(8.0, "Good")]
    [InlineData(7.99, "Average")]
    [InlineData(6.0, "Average")]
    [InlineData(5.99, "Weak")]
    public void ClassifyLevel_ShouldRespectThresholds(double score, string expected)
    {
        var level = SoftSkillCalculator.ClassifyLevel(score);

        Assert.Equal(expected, level);
    }
}

