using Microsoft.EntityFrameworkCore;

namespace Soff_skil.Data;

public static class LegacySchemaPatcher
{
    public static async Task PatchAsync(ApplicationDbContext dbContext, ILogger logger, CancellationToken cancellationToken = default)
    {
        var commands = new[]
        {
            "IF OBJECT_ID(N'teachers', N'U') IS NOT NULL AND COL_LENGTH('teachers', 'user_id') IS NULL ALTER TABLE teachers ADD user_id INT NULL;",
            "IF OBJECT_ID(N'teachers', N'U') IS NOT NULL AND COL_LENGTH('teachers', 'UserId') IS NOT NULL AND COL_LENGTH('teachers', 'user_id') IS NOT NULL BEGIN EXEC('UPDATE teachers SET user_id = UserId WHERE UserId IS NOT NULL AND (user_id IS NULL OR user_id = 0 OR user_id <> UserId)'); END;",
            "IF OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'class_code') IS NULL ALTER TABLE students ADD class_code NVARCHAR(20) NULL;",
            "IF OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'teacher_id') IS NULL ALTER TABLE students ADD teacher_id INT NULL;",
            "IF OBJECT_ID(N'IX_students_class_code', N'IX') IS NOT NULL DROP INDEX IX_students_class_code ON students;",
            "IF OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'ClassCode') IS NOT NULL AND COL_LENGTH('students', 'class_code') IS NOT NULL BEGIN EXEC('UPDATE students SET class_code = ClassCode WHERE ClassCode IS NOT NULL AND (class_code IS NULL OR class_code <> ClassCode)'); END;",
            "IF OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'TeacherId') IS NOT NULL AND COL_LENGTH('students', 'teacher_id') IS NOT NULL BEGIN EXEC('UPDATE students SET teacher_id = TeacherId WHERE TeacherId IS NOT NULL AND (teacher_id IS NULL OR teacher_id = 0 OR teacher_id <> TeacherId)'); END;",
            "IF OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'UserId') IS NOT NULL AND COL_LENGTH('students', 'user_id') IS NOT NULL BEGIN EXEC('UPDATE students SET user_id = UserId WHERE UserId IS NOT NULL AND (user_id IS NULL OR user_id = 0 OR user_id <> UserId)'); END;",

            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'communication') IS NULL ALTER TABLE soft_skill_result ADD communication FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_communication DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'teamwork') IS NULL ALTER TABLE soft_skill_result ADD teamwork FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_teamwork DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'critical_thinking') IS NULL ALTER TABLE soft_skill_result ADD critical_thinking FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_critical_thinking DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'time_management') IS NULL ALTER TABLE soft_skill_result ADD time_management FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_time_management DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'participation_rate') IS NULL ALTER TABLE soft_skill_result ADD participation_rate FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_participation_rate DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'contribution_rate') IS NULL ALTER TABLE soft_skill_result ADD contribution_rate FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_contribution_rate DEFAULT (0);",
            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL AND COL_LENGTH('soft_skill_result', 'on_time_rate') IS NULL ALTER TABLE soft_skill_result ADD on_time_rate FLOAT NOT NULL CONSTRAINT DF_soft_skill_result_on_time_rate DEFAULT (0);",

            "IF OBJECT_ID(N'soft_skill_result', N'U') IS NOT NULL UPDATE s SET communication = CASE WHEN communication = 0 AND score > 0 THEN score ELSE communication END, teamwork = CASE WHEN teamwork = 0 AND score > 0 THEN score ELSE teamwork END, critical_thinking = CASE WHEN critical_thinking = 0 AND score > 0 THEN score ELSE critical_thinking END, time_management = CASE WHEN time_management = 0 AND score > 0 THEN score ELSE time_management END, participation_rate = CASE WHEN participation_rate = 0 AND score > 0 THEN 70 ELSE participation_rate END, contribution_rate = CASE WHEN contribution_rate = 0 AND score > 0 THEN 70 ELSE contribution_rate END, on_time_rate = CASE WHEN on_time_rate = 0 AND score > 0 THEN 70 ELSE on_time_rate END FROM soft_skill_result s;",

            "IF OBJECT_ID(N'users', N'U') IS NOT NULL AND OBJECT_ID(N'teachers', N'U') IS NOT NULL AND COL_LENGTH('teachers', 'user_id') IS NOT NULL BEGIN DECLARE @TeacherUserId INT = (SELECT TOP (1) id FROM users WHERE role IN ('teacher', 'Teacher') ORDER BY id); IF @TeacherUserId IS NOT NULL UPDATE teachers SET user_id = @TeacherUserId WHERE user_id IS NULL OR user_id = 0; END;",
            "IF OBJECT_ID(N'teachers', N'U') IS NOT NULL AND OBJECT_ID(N'students', N'U') IS NOT NULL AND COL_LENGTH('students', 'teacher_id') IS NOT NULL BEGIN DECLARE @TeacherId INT = (SELECT TOP (1) id FROM teachers ORDER BY id); IF @TeacherId IS NOT NULL UPDATE students SET teacher_id = @TeacherId WHERE teacher_id IS NULL OR teacher_id = 0; END;"
        };

        foreach (var command in commands)
        {
            await dbContext.Database.ExecuteSqlRawAsync(command, cancellationToken);
        }

        logger.LogInformation("Legacy schema patch completed.");
    }
}
